@{
    ViewData["Title"] = "Dashboard";
}

<!-- Welcome Row -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h2 class="text-white mb-2">Welcome back, Admin! 👋</h2>
                        <p class="text-white-50 mb-0">Here's what's happening with your organization today.</p>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <span class="badge bg-white text-primary p-3">
                            <i class="far fa-calendar-alt me-2"></i> @DateTime.Now.ToString("dddd, MMM dd")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="fas fa-users text-primary fa-2x"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Total Employees</h6>
                        <h3 class="fw-bold mb-0">156</h3>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="badge bg-success bg-opacity-10 text-success">
                        <i class="fas fa-arrow-up me-1"></i> +12% from last month
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="fas fa-user-check text-success fa-2x"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Active Employees</h6>
                        <h3 class="fw-bold mb-0">142</h3>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="badge bg-success bg-opacity-10 text-success">
                        <i class="fas fa-check-circle me-1"></i> 91% active
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="fas fa-clock text-warning fa-2x"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">On Leave Today</h6>
                        <h3 class="fw-bold mb-0">8</h3>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="badge bg-warning bg-opacity-10 text-warning">
                        <i class="fas fa-calendar-day me-1"></i> 5 pending
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="fas fa-building text-info fa-2x"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Departments</h6>
                        <h3 class="fw-bold mb-0">12</h3>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="@Url.Action("Index", "Department")" class="text-decoration-none small">
                        View all <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0">
                    <i class="fas fa-chart-line text-primary me-2"></i>Employee Growth
                </h5>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        This Year
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">This Month</a></li>
                        <li><a class="dropdown-item" href="#">Last Month</a></li>
                        <li><a class="dropdown-item" href="#">This Year</a></li>
                    </ul>
                </div>
            </div>
            <div class="card-body">
                <canvas id="employeeChart" style="height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0">
                <h5 class="fw-semibold mb-0">
                    <i class="fas fa-chart-pie text-success me-2"></i>Department Distribution
                </h5>
            </div>
            <div class="card-body">
                <canvas id="departmentChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activities & Upcoming Leaves -->
<div class="row g-4 mb-4">
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0">
                    <i class="fas fa-history text-info me-2"></i>Recent Activities
                </h5>
                <a href="#" class="text-decoration-none small">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item border-0 py-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-2">
                                    <i class="fas fa-user-plus text-primary"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <p class="mb-0 fw-medium">John Doe joined as Software Developer</p>
                                <small class="text-muted"><i class="far fa-clock me-1"></i>2 hours ago</small>
                            </div>
                        </div>
                    </div>
                    <div class="list-group-item border-0 py-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-success bg-opacity-10 rounded-circle p-2">
                                    <i class="fas fa-check-circle text-success"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <p class="mb-0 fw-medium">Leave request approved for Jane Smith</p>
                                <small class="text-muted"><i class="far fa-clock me-1"></i>5 hours ago</small>
                            </div>
                        </div>
                    </div>
                    <div class="list-group-item border-0 py-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-warning bg-opacity-10 rounded-circle p-2">
                                    <i class="fas fa-clock text-warning"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <p class="mb-0 fw-medium">New leave request from Mike Johnson</p>
                                <small class="text-muted"><i class="far fa-clock me-1"></i>1 day ago</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0">
                    <i class="fas fa-calendar-alt text-warning me-2"></i>Upcoming Leaves
                </h5>
                <a href="#" class="text-decoration-none small">View Calendar</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">Employee</th>
                                <th class="border-0">Type</th>
                                <th class="border-0">Duration</th>
                                <th class="border-0">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <div class="fw-medium">John Doe</div>
                                    <small class="text-muted">IT Department</small>
                                </td>
                                <td><span class="badge bg-info bg-opacity-10 text-info px-3 py-2">Annual</span></td>
                                <td>Mar 15 - Mar 20 <br><small class="text-muted">6 days</small></td>
                                <td><span class="badge bg-success bg-opacity-10 text-success px-3 py-2">Approved</span></td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="fw-medium">Jane Smith</div>
                                    <small class="text-muted">HR Department</small>
                                </td>
                                <td><span class="badge bg-info bg-opacity-10 text-info px-3 py-2">Sick</span></td>
                                <td>Mar 10 - Mar 12 <br><small class="text-muted">3 days</small></td>
                                <td><span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2">Pending</span></td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="fw-medium">Mike Johnson</div>
                                    <small class="text-muted">Finance</small>
                                </td>
                                <td><span class="badge bg-info bg-opacity-10 text-info px-3 py-2">Annual</span></td>
                                <td>Mar 18 - Mar 22 <br><small class="text-muted">5 days</small></td>
                                <td><span class="badge bg-success bg-opacity-10 text-success px-3 py-2">Approved</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h5 class="text-white mb-2">Need to take action?</h5>
                        <p class="text-white-50 mb-lg-0">Quickly perform common tasks from here.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="d-flex gap-2 justify-content-lg-end">
                            <a href="@Url.Action("Create", "Employee")" class="btn btn-light">
                                <i class="fas fa-user-plus me-2"></i>Add Employee
                            </a>
                            <a href="@Url.Action("Create", "Department")" class="btn btn-outline-light">
                                <i class="fas fa-building me-2"></i>Add Department
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Employee Chart
            const ctx1 = document.getElementById('employeeChart').getContext('2d');
            new Chart(ctx1, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                    datasets: [{
                        label: 'Employees',
                        data: [120, 125, 130, 135, 140, 145, 148, 150, 152, 154, 155, 156],
                        borderColor: '#4e73df',
                        backgroundColor: 'rgba(78, 115, 223, 0.05)',
                        borderWidth: 3,
                        pointBackgroundColor: '#4e73df',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.3,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.05)' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Department Chart
            const ctx2 = document.getElementById('departmentChart').getContext('2d');
            new Chart(ctx2, {
                type: 'doughnut',
                data: {
                    labels: ['IT', 'HR', 'Finance', 'Marketing', 'Sales'],
                    datasets: [{
                        data: [45, 20, 25, 30, 36],
                        backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b'],
                        borderWidth: 0,
                        hoverOffset: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { boxWidth: 12, padding: 15 }
                        }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
}