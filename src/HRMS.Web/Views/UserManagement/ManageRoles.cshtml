@using HRMS.Web.ViewModels
@model UserRoleViewModel
@{
    ViewData["Title"] = "Manage User Roles";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-user-tag mr-2"></i> Manage Roles for @Model.User?.Email
        </h3>
        <div class="card-tools">
            <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
    <div class="card-body">
        <form asp-action="ManageRoles" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.User?.Id" />

            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Available Roles</h5>
                        </div>
                        <div class="card-body">
                            @for (int i = 0; i < Model.AvailableRoles!.Count; i++)
                            {
                                <div class="form-check mb-2">
                                    <input type="hidden" asp-for="@Model.AvailableRoles[i].RoleName" />
                                    <input asp-for="@Model.AvailableRoles[i].IsSelected" class="form-check-input" />
                                    <label class="form-check-label">
                                        @if (Model.AvailableRoles[i].RoleName == "Admin")
                                        {
                                            <span class="badge badge-danger">@Model.AvailableRoles[i].RoleName</span>
                                        }
                                        else if (Model.AvailableRoles[i].RoleName == "HR")
                                        {
                                            <span class="badge badge-success">@Model.AvailableRoles[i].RoleName</span>
                                        }
                                        else if (Model.AvailableRoles[i].RoleName == "Manager")
                                        {
                                            <span class="badge badge-warning">@Model.AvailableRoles[i].RoleName</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">@Model.AvailableRoles[i].RoleName</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>