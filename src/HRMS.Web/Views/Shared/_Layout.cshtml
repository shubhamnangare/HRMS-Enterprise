<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - HRMS Enterprise</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top px-4">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="@Url.Action("Index", "Dashboard")">
                <img src="~/images/profile.png" alt="HRMS" width="35" height="35" class="rounded-circle me-2">
                <span class="fw-semibold">HRMS Enterprise</span>
            </a>

            <div class="d-flex align-items-center ms-auto">
                <!-- Notifications -->
                <div class="dropdown me-3">
                    <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-bell fs-5 text-white"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end shadow-lg border-0" style="width: 300px;">
                        <div class="dropdown-header bg-light py-3">
                            <h6 class="mb-0">Notifications</h6>
                        </div>
                        <div class="dropdown-item py-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                    <i class="fas fa-user-plus text-primary"></i>
                                </div>
                                <div>
                                    <p class="mb-0 fw-medium">New employee joined</p>
                                    <small class="text-muted">5 min ago</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- User Menu -->
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
    @{
        var userName = User.Identity?.Name ?? "";
        var truncatedName = userName.Length > 15 ? userName.Substring(0, 12) + "..." : userName;
    }

    <!-- Sidebar -->
    <aside class="sidebar bg-white shadow-lg" style="position: fixed; top: 60px; left: 0; width: 260px; height: calc(100vh - 60px); overflow-y: auto; z-index: 1000;">
        <div class="p-3">
            <!-- User Info -->
            <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-3">
                <img src="~/images/user-placeholder.png" alt="User" class="rounded-circle me-3" width="45" height="45">
                <div>
                    <h6 class="mb-0 fw-semibold" title="@userName">@truncatedName</h6>
                    <small class="text-muted">Administrator</small>
                </div>
            </div>

            <!-- Search -->
            <div class="mb-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control bg-light border-0" placeholder="Search...">
                </div>
            </div>

            <!-- Navigation Menu -->
            <nav>
                <ul class="nav flex-column">
                    <!-- Dashboard -->
                    <li class="nav-item mb-2">
                        <a href="@Url.Action("Index", "Dashboard")"
                           class="nav-link d-flex align-items-center px-3 py-2 rounded-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active bg-primary text-white" : "text-dark")">
                            <i class="fas fa-tachometer-alt me-3" style="width: 20px;"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <!-- Employees Dropdown -->
                    <li class="nav-item mb-2">
                        <a href="#employeesMenu" data-bs-toggle="collapse"
                           class="nav-link d-flex align-items-center justify-content-between px-3 py-2 rounded-3 text-dark">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-users me-3" style="width: 20px;"></i>
                                <span>Employees</span>
                            </div>
                            <i class="fas fa-chevron-down" style="font-size: 12px;"></i>
                        </a>
                        <div class="collapse show" id="employeesMenu">
                            <div class="ms-4 mt-2">
                                <a href="@Url.Action("Index", "Employee")"
                                   class="d-block py-2 px-3 rounded-3 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "bg-light text-primary" : "text-secondary")">
                                    <i class="fas fa-list me-2"></i> All Employees
                                </a>
                                <a href="@Url.Action("Create", "Employee")"
                                   class="d-block py-2 px-3 rounded-3 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "bg-light text-primary" : "text-secondary")">
                                    <i class="fas fa-plus me-2"></i> Add Employee
                                </a>
                            </div>
                        </div>
                    </li>

                    <!-- Departments Dropdown -->
                    <li class="nav-item mb-2">
                        <a href="#deptsMenu" data-bs-toggle="collapse"
                           class="nav-link d-flex align-items-center justify-content-between px-3 py-2 rounded-3 text-dark">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-building me-3" style="width: 20px;"></i>
                                <span>Departments</span>
                            </div>
                            <i class="fas fa-chevron-down" style="font-size: 12px;"></i>
                        </a>
                        <div class="collapse show" id="deptsMenu">
                            <div class="ms-4 mt-2">
                                <a href="@Url.Action("Index", "Department")"
                                   class="d-block py-2 px-3 rounded-3 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "bg-light text-primary" : "text-secondary")">
                                    <i class="fas fa-list me-2"></i> All Departments
                                </a>
                                <a href="@Url.Action("Create", "Department")"
                                   class="d-block py-2 px-3 rounded-3 text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "bg-light text-primary" : "text-secondary")">
                                    <i class="fas fa-plus me-2"></i> Add Department
                                </a>
                            </div>
                        </div>
                    </li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item mt-3 mb-2">
                            <small class="text-uppercase text-muted fw-bold px-3">Admin</small>
                        </li>
                        <li class="nav-item mb-2">
                            <a href="@Url.Action("Index", "UserManagement")"
                               class="nav-link d-flex align-items-center px-3 py-2 rounded-3 text-dark">
                                <i class="fas fa-users-cog me-3" style="width: 20px;"></i>
                                <span>User Management</span>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </aside>

    <!-- Main Content -->
    <main style="margin-left: 260px; margin-top: 60px; padding: 20px; background: #f8f9fa; min-height: calc(100vh - 60px);">
        <!-- Breadcrumb -->
        <div class="d-flex align-items-center mb-4">
            <h4 class="mb-0 fw-semibold">@ViewData["Title"]</h4>
            <nav class="ms-auto">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")" class="text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                </ol>
            </nav>
        </div>

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Page Content -->
        @RenderBody()
    </main>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js"></script>

    <!-- This renders any scripts from the views -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>