@using HRMS.Core.Enums
@model IEnumerable<DepartmentListDto>
@{
    ViewData["Title"] = "Departments";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-building mr-2"></i> Department Management
        </h3>
        <div class="card-tools">
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">
                <i class="fas fa-plus"></i> Add New Department
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover dataTable">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Manager</th>
                        <th>Employee Count</th>
                        <th>Budget</th>
                        <th>Location</th>
                        <th width="150">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var dept in Model)
                        {
                            <tr>
                                <td><span class="badge badge-secondary">@dept.Code</span></td>
                                <td>@dept.Name</td>
                                <td>@(dept.ManagerName ?? "Not Assigned")</td>
                                <td><span class="badge badge-info">@dept.EmployeeCount</span></td>
                                <td>@(dept.Budget?.ToString("C0") ?? "N/A")</td>
                                
                                <td>
                                    <div class="btn-group">
                                        <a href="@Url.Action("Details", new { id = dept.Id })"
                                           class="btn btn-info btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = dept.Id })"
                                           class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <button type="button"
                                                    onclick="confirmDelete('deleteForm_@dept.Id', '@dept.Name')"
                                                    class="btn btn-danger btn-sm" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                            <form id="deleteForm_@dept.Id"
                                                  asp-action="Delete"
                                                  asp-route-id="@dept.Id"
                                                  method="post"
                                                  style="display:none;">
                                                @Html.AntiForgeryToken()
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">No departments found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize tooltips
            $('[title]').tooltip();
        });
    </script>
}