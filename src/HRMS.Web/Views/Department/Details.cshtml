@model DepartmentDetailDto
@{
    ViewData["Title"] = "Department Details";
}

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-building mr-2"></i> Department Information
                </h3>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th width="40%">Code:</th>
                        <td><span class="badge badge-secondary">@Model.Code</span></td>
                    </tr>
                    <tr>
                        <th>Name:</th>
                        <td><strong>@Model.Name</strong></td>
                    </tr>
                    <tr>
                        <th>Description:</th>
                        <td>@(Model.Description ?? "N/A")</td>
                    </tr>
                    <tr>
                        <th>Location:</th>
                        <td>@(Model.Location ?? "N/A")</td>
                    </tr>
                    <tr>
                        <th>Phone:</th>
                        <td>@(Model.Phone ?? "N/A")</td>
                    </tr>
                    <tr>
                        <th>Email:</th>
                        <td>@(Model.Email ?? "N/A")</td>
                    </tr>
                    <tr>
                        <th>Budget:</th>
                        <td>@(Model.Budget?.ToString("C0") ?? "N/A")</td>
                    </tr>
                    <tr>
                        <th>Manager:</th>
                        <td>
                            @if (!string.IsNullOrEmpty(Model.ManagerName))
                            {
                                <span class="badge badge-info">@Model.ManagerName</span>
                            }
                            else
                            {
                                <span class="text-muted">Not Assigned</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Total Employees:</th>
                        <td><span class="badge badge-primary">@Model.EmployeeCount</span></td>
                    </tr>
                    <tr>
                        <th>Created:</th>
                        <td>@Model.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                </table>

                <div class="mt-3">
                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-users mr-2"></i> Employees in @Model.Name
                </h3>
            </div>
            <div class="card-body">
                @if (Model.Employees != null && Model.Employees.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Employee Code</th>
                                    <th>Name</th>
                                    <th>Job Title</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in Model.Employees)
                                {
                                    <tr>
                                        <td>@emp.EmployeeCode</td>
                                        <td>@emp.FullName</td>
                                        <td>@emp.JobTitle</td>
                                        <td>@emp.Email</td>
                                        <td>
                                            <span class="badge badge-@emp.StatusBadgeClass">@emp.Status</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Employee", new { id = emp.Id })"
                                               class="btn btn-info btn-sm">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-center text-muted my-4">No employees in this department.</p>
                }
            </div>
        </div>
    </div>
</div>